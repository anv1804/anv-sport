generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Post {
  id            Int            @id @default(autoincrement())
  title         String
  excerpt       String?
  content       String
  imageUrl      String?
  author        String         @default("Admin")
  status        String         @default("DRAFT")
  isAiGenerated Boolean        @default(false)
  type          String         @default("STANDARD")
  metadata      String?
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  categoryPosts CategoryPost[]
  zonePosts     ZonePost[]
  categories    Category[]     @relation("CategoryToPost")

  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([publishedAt(sort: Desc)])
  @@index([type])
}

model Zone {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pageId      String?
  page        Page?      @relation(fields: [pageId], references: [id])
  zonePosts   ZonePost[]
}

model ZonePost {
  id             String    @id @default(cuid())
  zoneId         String
  postId         Int
  position       Int       @default(0)
  createdAt      DateTime  @default(now())
  isPrinted      Boolean   @default(false)
  printEndTime   DateTime?
  printStartTime DateTime?
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  zone           Zone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@unique([zoneId, postId])
  @@index([zoneId, position])
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  type        String   @default("CUSTOM")
  content     String?
  settings    String?
  status      String   @default("PUBLISHED")
  isDeletable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  zones       Zone[]
}

model Category {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  description   String?
  parentId      String?
  isActive      Boolean            @default(true)
  createdBy     String             @default("Admin")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  parent        Category?          @relation("CategoryToCategory", fields: [parentId], references: [id])
  children      Category[]         @relation("CategoryToCategory")
  categoryPosts CategoryPost[]
  posts         Post[]             @relation("CategoryToPost")
  clonerSources AutoClonerSource[]
}

model CategoryPost {
  id             String    @id @default(cuid())
  categoryId     String
  postId         Int
  position       Int       @default(0)
  createdAt      DateTime  @default(now())
  isPrinted      Boolean   @default(false)
  printEndTime   DateTime?
  printStartTime DateTime?
  category       Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  post           Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([categoryId, postId])
  @@index([categoryId, position])
}

model AdPlacement {
  id        String   @id @default(cuid())
  slotId    String   @unique
  name      String
  imageUrl  String?
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model User {
  id          String   @id @default(cuid())
  supabaseUid String   @unique
  email       String   @unique
  role        String   @default("USER")
  createdAt   DateTime @default(now())
}

model Club {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sportType String   @default("FOOTBALL")
  logo      String?
  basicInfo String?
  countryId String?
  leagueId  String?
  achievements String?
  wikiUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  country   Country? @relation(fields: [countryId], references: [id])
  league    League?  @relation(fields: [leagueId], references: [id])
  entities  Entity[]
}

model Entity {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  type         String   @default("FOOTBALL_PLAYER")
  avatar       String?
  clubId       String?
  basicInfo    String?
  achievements String?
  stats        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  club         Club?    @relation(fields: [clubId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tactical_formations {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  coordinates Json
  created_at  DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
}

model AILog {
  id           String   @id @default(cuid())
  prompt       String?  @db.Text
  modelUsed    String?
  status       String   @default("SUCCESS") // SUCCESS, ERROR
  errorMessage String?  @db.Text
  tokenCount   Int      @default(0) // Số token tương đối hoặc trả về từ API
  durationMs   Int      @default(0) // Thời gian xử lý
  createdAt    DateTime @default(now())
}

model Sport {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leagues   League[]
}

model Country {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  code      String?   // ISO code (VD: VN, UK, US)
  flag      String?   // URL hình ảnh cờ
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  leagues   League[]
  clubs     Club[]
}

model League {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  logo        String?
  sportId     String
  countryId   String?   // Null nếu là giải đấu quốc tế (VD: World Cup)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  sport       Sport     @relation(fields: [sportId], references: [id])
  country     Country?  @relation(fields: [countryId], references: [id])
  clubs       Club[]
}

model AutoClonerSource {
  id           String   @id @default(cuid())
  url          String
  categoryId   String
  categorySlug String
  isActive     Boolean  @default(true)
  daysLimit    Int      @default(7)
  isForeign    Boolean  @default(false)
  lastRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

